{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "almond",
  "name": "AdvancedModList",
  "description": "Documentation for AdvancedModList — a Paper plugin that detects client-side Minecraft mods.",
  "colors": {
    "primary": "#166E3F",
    "light": "#26BD6C",
    "dark": "#166E3F"
  },
  "favicon": "/favicon.ico",
  "icons": {
    "library": "lucide"
  },
  "styling": {
    "eyebrows": "breadcrumbs"
  },
  "contextual": {
    "options": ["view", "assistant"]
  },
  "navigation": {
    "global": {
      "anchors": [
        {
          "anchor": "Home",
          "icon": "house",
          "href": "/"
        }
      ]
    },
    "directory": "card",
    "groups": [
      {
        "group": "Getting Started",
        "icon": "rocket",
        "expanded": true,
        "pages": [
          "getting-started/installation"
        ]
      },
      {
        "group": "Configuration",
        "icon": "settings",
        "expanded": true,
        "pages": [
          "configuration/config",
          "configuration/mod-files"
        ]
      },
      {
        "group": "Modules",
        "icon": "blocks",
        "expanded": true,
        "pages": [
          "modules/overview"
        ]
      },
      {
        "group": "Reference",
        "icon": "book-open",
        "expanded": true,
        "pages": [
          "reference/commands",
          "reference/permissions",
          "reference/placeholderapi"
        ]
      },
      {
        "group": "Advanced",
        "icon": "flask-conical",
        "expanded": true,
        "pages": [
          "advanced/detection-behavior",
          "advanced/troubleshooting"
        ]
      }
    ]
  },
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "navbar": {
    "links": []
  },
  "footer": {
    "socials": {}
  }
}
